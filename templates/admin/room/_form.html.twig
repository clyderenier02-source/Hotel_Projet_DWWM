<div class="admin-room-form__group">
    {{ form_label(form.name, 'Nom', { label_attr: { class: 'admin-room-form__label' } }) }}
    {{ form_widget(form.name, { attr: { class: 'admin-room-form__input' } }) }}
    {{ form_errors(form.name) }}
</div>

<div class="admin-room-form__group">
    {{ form_label(form.description_courte, 'Description courte', { label_attr: { class: 'admin-room-form__label' } }) }}
    {{ form_widget(form.description_courte, { attr: { class: 'admin-room-form__textarea' } }) }}
    {{ form_errors(form.description_courte) }}
</div>

<div class="admin-room-form__group">
    {{ form_label(form.description, 'Description complète', { label_attr: { class: 'admin-room-form__label' } }) }}
    {{ form_widget(form.description, { attr: { class: 'admin-room-form__textarea' } }) }}
    {{ form_errors(form.description) }}
</div>

<div class="admin-room-form__group">
    {{ form_label(form.price_night, 'Prix par nuit (€)', { label_attr: { class: 'admin-room-form__label' } }) }}
    {{ form_widget(form.price_night, { attr: { class: 'admin-room-form__input' } }) }}
    {{ form_errors(form.price_night) }}
</div>
