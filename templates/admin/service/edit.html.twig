{% extends 'base.admin.html.twig' %}

{% block title %}Modifier{{ service.name }}{% endblock %}

{% block body %}
<div class="admin-service-form">
    <div class="admin-service-form__header">
        <h1 class="admin-service-form__titlePage">Modifier le service</h1>
        <a href="{{ path('app_admin_service_index') }}" class="admin-service-form__btn--back">Retour aux services</a>
    </div>

    <div class="admin-service-form__card">
        {{ form_start(form, { attr: { id: 'edit_form'} }) }}
        <div class="admin-service-form__form">
            {% include 'admin/service/_form.html.twig' %}
        </div>
        {{ form_end(form) }}
        <div class="admin-service-form__actions">
            {{ include('admin/service/_delete_form.html.twig', { service: service })}}
            <button form="edit_form" type="submit" class="admin-service-form__btn--save">Enregistrer</button>
        </div>
    </div>
</div>
{% endblock %}