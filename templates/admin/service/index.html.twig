{% extends 'base.admin.html.twig' %}

{% block title %}Service index{% endblock %}

{% block body %}
    {% for service in services %}
        <div class="card">
            

            <div class="card__content">
                <h3 class="card__name">{{ service.name }}</h3>
                <p class="card__description">{{ service.description | slice(0, 73) ~ '...' }}</p>
                <p class="roomCard__price">{{ service.price }}€</p>
                <p>{{ service.time }}h</p>

                <div class="card__actions">
                    <a href="{{ path('app_service_edit', {'id': service.id}) }}">edit</a>
                    {{ include('service/_delete_form.html.twig') }}
                </div>
            </div>
        </div>
        {% endfor %}
        <div class="card__actions">
            <a href="{{ path('app_service_new') }}">Create new</a>
        </div>
{% endblock %}
