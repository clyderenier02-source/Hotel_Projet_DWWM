{% extends 'base.admin.html.twig' %}

{% block title %}Admin - Rooms{% endblock %}

{% block body %}
<section class="admin-room">
    <div class="admin-room__header">
        <div class="admin-room__header-sub">
            <h4>Chambres</h4>
        <a href="{{ path('app_room_new') }}">Create new</a>
        </div>
    </div>
    {% for room in rooms %}
        <div class="admin-room__card">
            <div class="admin-room__card-content">
                <h3 class="admin-room__card-name">{{ room.name }}</h3>
                <p class="admin-room__card-description">{{ room.description | slice(0, 80) ~ '...' }}</p>

                <div class="admin-room__card-actions">
                    <p class="admin-room__card-price">{{ room.priceNight }}€ / nuit</p>
                    <div class="admin-room__card-actions-mode">
                        <a href="{{ path('app_room_edit', {'id': room.id}) }}">Edit</a>
                        {{ include('room/_delete_form.html.twig') }}
                    </div>
                </div>
            </div>
        </div>
    {% endfor %}
</section>
{% endblock %}