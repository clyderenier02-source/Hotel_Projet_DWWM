{% extends 'base.admin.html.twig' %}

{% block title %}Admin - Rooms{% endblock %}

{% block body %}
<section class="admin-room">
    <div class="admin-room__header">
        <h1 class="admin-room__titlePage">Chambres</h1>

        <a href="{{ path('app_admin_room_new') }}" class="admin-room__btn admin-room__btn--create">+ Ajouter des chambres</a>
    </div>
    <div class="admin-room__list">
    {% for room in rooms %}
        <div class="admin-room__card">
            <div class="admin-room__card-content">
                <div class="admin-room__card-info">
                    <h3 class="admin-room__card-name">{{ room.name }}</h3>
                    <p class="admin-room__card-description">{{ room.description | slice(0, 80) ~ '...' }}</p>

                    <div class="admin-room__card-actions">
                        <p class="admin-room__card-price">{{ room.priceNight }}€ / nuit</p>

                        <div class="admin-room__card-actions-mode">
                            <a href="{{ path('app_admin_room_edit', {'id': room.id}) }}" class="admin-room__btn admin-room__btn--edit">Modifier</a>
                            {{ include('admin/room/_delete_form.html.twig', { room: room }) }}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% endfor %}
    </div>
</section>
{% endblock %}