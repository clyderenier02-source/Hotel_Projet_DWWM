{% extends 'base.admin.html.twig' %}

{% block title %}Utilisateurs{% endblock %}

{% block body %}
<section class="user user--admin">
    <div class="user__list">
        <div class="user__header">
            <h1 class="user__titlePage">Utilisateurs</h1>
        </div>
        <div class="user__item">
            {% for user in users %}
                <div class="user__card">
                    <div class="user__content">
                        <div class="user__identity">
                            <h3 class="user__email">{{ user.email }}</h3>
                            <p class="user__roles">{{ user.roles|join(', ') }}</p>
                        </div>
                        <div class="user__actions">
                            {% if 'ROLE_ADMIN' in user.roles %}
                                <form method="post" action="{{ path('app_admin_user_demote', {'id': user.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('demote' ~ user.id) }}">
                                    <button class="user__btn user__btn--danger"type="submit">Retirer admin</button>
                                </form>
                            {% else %}
                                <form method="post" action="{{ path('app_admin_user_promote', {'id': user.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('promote' ~ user.id) }}">
                                    <button class="user__btn user__btn--success" type="submit">Promouvoir admin</button>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="user__empty">
                    <p>Aucun utilisateur</p>
                </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}