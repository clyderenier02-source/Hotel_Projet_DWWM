{% extends 'base.html.twig' %}

{% block title %}Payment index{% endblock %}

{% block body %}
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Total</th>
                <th>Date_payment</th>
                <th>Mode</th>
                <th>Status</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for payment in payments %}
            <tr>
                <td>{{ payment.id }}</td>
                <td>{{ payment.total }}</td>
                <td>{{ payment.datePayment ? payment.datePayment|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ payment.mode }}</td>
                <td>{{ payment.status }}</td>
                <td>
                    <a href="{{ path('app_payment_show', {'id': payment.id}) }}">show</a>
                    <a href="{{ path('app_payment_edit', {'id': payment.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    {# <a href="{{ path('app_payment_new', {id: room.id}) }}">Create new</a> #}
{% endblock %}
