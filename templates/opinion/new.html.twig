{% extends 'base.html.twig' %}

{% block title %}Laisser un avis{% endblock %}

{% block body %}
<section class="opinionForm">
    <div class="opinionForm__card">
        <div class="opinionForm__header">
            <span class="opinionForm__badge">Hôtel</span>
            <h1 class="opinionForm__title">Votre avis</h1>
            <p class="opinionForm__subtitle">Partagez votre expérience avec nous</p>
        </div>

        {{ form_start(form) }}
            {{ form_widget(form.note, {'attr': {'id': 'opinion_note', 'style': 'display:none'}}) }}

            <div class="opinionForm__rating">
                <div class="opinionForm__stars" id="star-widget">
                    {% for i in 1..5 %}
                        <img src="{{ asset('svg/star.svg') }}" class="opinionForm__star" data-value="{{ i }}" alt="étoile">
                    {% endfor %}
                </div>
                <p class="opinionForm__rating-label opinion__rating-label--empty" id="rating-text">
                    Sélectionnez une note
                </p>
            </div>

            <div class="opinionForm__field">
                <label class="opinionForm__label" for="opinion_comment">Votre commentaire</label>
                {{ form_widget(form.comment, {
                    'attr': {
                        'class': 'opinionForm__textarea',
                        'id': 'opinion_comment',
                        'placeholder': 'Décrivez votre séjour...',
                        'rows': '5'
                    }
                }) }}
                <span class="opinionForm__counter" id="char-wrap">
                    <span id="char-count">0</span>/500
                </span>
            </div>

            {% if form.note.vars.errors|length > 0 or form.comment.vars.errors|length > 0 %}
                <div class="opinionForm__errors">
                    {{ form_errors(form.note) }}
                    {{ form_errors(form.comment) }}
                </div>
            {% endif %}
            <button type="submit" class="opinionForm__submit" id="btn-submit" disabled>Complétez le formulaire</button>
        {{ form_end(form) }}
    </div>
</section>
{% endblock %}