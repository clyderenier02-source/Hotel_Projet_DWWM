<div class="admin-service-form__group">
    {{ form_label(form.name, 'Nom', { label_attr: { class: 'admin-service-form__label' } }) }}
    {{ form_widget(form.name, { attr: { class: 'admin-service-form__input' } }) }}
    {{ form_errors(form.name) }}
</div>

<div class="admin-service-form__group">
    {{ form_label(form.description, 'Description', { label_attr: { class: 'admin-service-form__label' } }) }}
    {{ form_widget(form.description, { attr: { class: 'admin-service-form__textarea' } }) }}
    {{ form_errors(form.description) }}
</div>

<div class="admin-service-form__group">
    {{ form_label(form.price, 'Prix (€)', { label_attr: { class: 'admin-service-form__label' } }) }}
    {{ form_widget(form.price, { attr: { class: 'admin-service-form__input' } }) }}
    {{ form_errors(form.price) }}
</div>

<div class="admin-service-form__group">
    {{ form_label(form.time, 'Durée (min)', { label_attr: { class: 'admin-service-form__label' } }) }}
    {{ form_widget(form.time, { attr: { class: 'admin-service-form__input' } }) }}
    {{ form_errors(form.time) }}
</div>