{% extends 'base.html.twig' %}

{% block title %}Avis clients{% endblock %}

{% block body %}
<div class="reviews-wrapper">

    <div class="reviews-header">
        <h1>Avis de nos clients</h1>
        {% if app.user %}
            <a href="{{ path('app_opinion_new') }}" class="btn-write">Laisser un avis</a>
        {% endif %}
    </div>

    {% for flash in app.flashes('success') %}
        <div class="flash flash--success">{{ flash }}</div>
    {% endfor %}

    {% for flash in app.flashes('error') %}
        <div class="flash flash--error">{{ flash }}</div>
    {% endfor %}

    {% if opinions is empty %}
        <p class="no-reviews">Aucun avis pour le moment. Soyez le premier !</p>
    {% else %}
        <div class="reviews-grid">
            {% for opinion in opinions %}
                <div class="review-card">
                    <div class="review-stars">
                        {% for i in 1..5 %}
                            {% if i <= opinion.note %}
                                <img src="{{ asset('svg/star.svg') }}" class="star star--filled" alt="étoile">
                            {% else %}
                                <img src="{{ asset('svg/star.svg') }}" class="star star--empty" alt="étoile vide">
                            {% endif %}
                        {% endfor %}
                        <span class="review-note">{{ opinion.note }}/5</span>
                    </div>
                    <p class="review-comment">{{ opinion.comment }}</p>
                    <div class="review-meta">
                        <span class="review-author">{{ opinion.reservation.user.email }}</span>
                        <span class="review-date">{{ opinion.dateSend|date('d/m/Y') }}</span>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}