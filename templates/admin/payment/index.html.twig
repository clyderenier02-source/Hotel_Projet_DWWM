{% extends 'base.admin.html.twig' %}

{% block title %}Payment index{% endblock %}

{% block body %}
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Total</th>
                <th>Date_payment</th>
                <th>Mode</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
        {% for payment in payments %}
            <tr>
                <td>{{ payment.id }}</td>
                <td>{{ payment.total }}</td>
                <td>{{ payment.datePayment ? payment.datePayment|date('Y-m-d') : '' }}</td>
                <td>{{ payment.mode }}</td>
                <td>{{ payment.status }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
