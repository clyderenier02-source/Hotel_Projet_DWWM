{% extends 'base.admin.html.twig' %}

{% block title %}Avis clients{% endblock %}

{% block body %}
<div class="admin-opinion">
    <div class="admin-opinion__header">
        <h1 class="admin-opinion__titlePage">Avis de nos clients</h1>
    </div>

    {% if opinions is empty %}
        <p class="admin-opinion__no-reviews">Aucun avis pour le moment. Soyez le premier !</p>
    {% else %}
        <div class="admin-opinion__card">
            {% for opinion in opinions %}
                <div class="admin-opinion__content">
                    <div class="admin-opinion__dates">
                        <p class="admin-opinion__date">{{ opinion.dateSend|date('d/m/Y') }}</p>

                        <div class="admin-opinion__stars">
                            {% for i in 1..5 %}
                                {% if i <= opinion.note %}
                                    <img src="{{ asset('svg/star.svg') }}" class="admin-opinion__star admin-opinion__star--filled" alt="étoile">
                                {% else %}
                                    <img src="{{ asset('svg/star.svg') }}" class="admin-opinion__star admin-opinion__star--empty" alt="étoile vide">
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>

                    <div class="admin-opinion__meta">
                        <p class="admin-opinion__author">{{ opinion.reservation.user.email }}</p>
                        <span class="admin-opinion__note">{{ opinion.note }}/5</span>
                    </div>

                    <p class="admin-opinion__comment">{{ opinion.comment }}</p>

                    {{ include('admin/opinion/_delete_form.html.twig') }}
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}