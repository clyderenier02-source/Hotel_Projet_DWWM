{% extends 'base.admin.html.twig' %}

{% block title %}Contacts{% endblock %}

{% block body %}
<section class="contact contact--admin">
    <div class="contact__list">
        <div class="contact__header">
            <h1 class="contact__titlePage">Contact</h1>
        </div>
        <div class="contact__item">
            {% for contact in contacts %}
                <div class="contact__card">
                    <div class="contact__content">
                        <div class="contact__info">
                            <p class="contact__email">{{ contact.email }}</p>

                            <p class="contact__message">{{ contact.message | slice(0, 120) }}</p>
                        </div>

                        <div class="contact__meta">
                            <p class="contact__date">{{ contact.dateSend|date('d/m/Y') }}</p>

                            <div class="contact__actions">
                                <a href="{{ path('app_admin_contact_show', {'id': contact.id}) }}"
                                    class="contact__btn contact__btn--view">
                                    Voir
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="contact__empty">
                    <p>Aucun message</p>
                </div>
            {% endfor %}
            </div>
    </div>
</section>
{% endblock %}